---
const { class: className, ...props } = Astro.props;
---
<svg viewBox="0 0 24 24" class={className} {...props}>
  <g fill="none" stroke="currentColor" stroke-linejoin="miter" stroke-linecap="butt" stroke-miterlimit="10" stroke-width="2">
    <polyline points="3 14 9 14 9 17 15 17 15 14 21 14" stroke-linecap="square"></polyline>
    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
  </g>
</svg>
