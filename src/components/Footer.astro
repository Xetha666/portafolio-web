---
import logoDark from "@/assets/logo-dark.webp";
import logoLight from "@/assets/logo-light.webp";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import { Image } from "astro:assets";
import Cat from "public/svg/Cat.svg";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const currentYear = new Date().getFullYear();
---

<footer class="w-full pt-12 pb-32 md:pb-12 px-8 flex flex-col md:flex-row justify-between items-center gap-6 border-t border-brand-outline-variant/30 bg-transparent animate-fade-in animate-duration-1000">
  <div class="font-manrope select-none text-xs mx-auto tracking-widest uppercase text-brand-on-surface-variant/60">
    <span class="flex items-center gap-1.5 grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition-all duration-300">
      © {currentYear} 
      <a href={lang === 'es' ? '/' : `/${lang}/`}>
        <Image src={logoLight} alt="bryan.dev Logo" class="h-5 w-auto block dark:hidden" loading="lazy" />
        <Image src={logoDark} alt="bryan.dev Logo" class="h-5 w-auto hidden dark:block" loading="lazy" />
      </a>
      — {t('footer.cat_lover')}
      <Cat class="size-5 inline-block opacity-50"/>
    </span>
  </div>
</footer>
