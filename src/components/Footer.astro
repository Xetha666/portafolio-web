---
import Cat from "public/svg/Cat.svg";
---
  
<footer class="w-full pt-12 pb-32 md:pb-12 px-8 flex flex-col md:flex-row justify-between items-center gap-6 border-t border-brand-outline-variant/30 bg-transparent">
  <div class="font-manrope text-xs mx-auto tracking-widest uppercase text-brand-on-surface-variant/60">
    <span class="flex items-center gap-1.5 grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition-all duration-300">
      © 2026 
      <img src="/logo-light.webp" alt="bryan.dev Logo" class="h-5 w-auto block dark:hidden" />
      <img src="/logo-dark.webp" alt="bryan.dev Logo" class="h-5 w-auto hidden dark:block" />
      — Amante de los gatos
      <Cat class="size-5 inline-block opacity-50"/>
    </span>
  </div>
</footer>
