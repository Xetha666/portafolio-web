---
import Email from "@/components/icons/Contact.astro";
import Copy from "public/svg/Copy.svg";
import Location from "public/svg/Location.svg";
import GithubIcon from "@/components/icons/Github.astro";
import WhatsAppIcon from "@/components/icons/WhatsApp.astro";
import DiscordIcon from "@/components/icons/Discord.astro";
import ContactForm from "@/components/ContactForm.astro";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="mb-16 scroll-mt-4 md:scroll-mt-24 lg:scroll-mt-28" id="contact">
  <div class="glass-panel rounded-4xl p-8 md:p-16 ghost-border relative overflow-hidden">
    <div class="absolute top-0 right-0 w-64 h-64 bg-brand-secondary/10 blur-huge -z-10"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 bg-brand-primary/10 blur-huge -z-10"></div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      <div class="flex flex-col gap-6 timeline-view animate-slide-in-left animate-range-[entry_5%_contain_30%]">
        <h2 class="font-headline select-none text-4xl font-bold">{t('contact.title')}</h2>
        <p class="font-body select-none text-brand-on-surface-variant text-lg">
          {t('contact.subtitle')}
        </p>
        <div class="mt-8 space-y-4">
          <div class="select-none flex items-center gap-4">
            <div class="w-12 h-12 rounded-full glass-panel ghost-border flex items-center justify-center text-brand-primary">
              <Email class="size-6" />
            </div>
            <div>
              <div class="font-label text-small uppercase text-brand-on-surface-variant">{t('contact.email_label')}</div>
            <button id="copy-email" class="font-body text-sm text-left hover:text-brand-primary transition-colors cursor-pointer flex items-center gap-2 group" title={t('contact.copy_email_title')} data-copied-text={t('contact.email_copied')}>
                <span id="email-display-text">{t('contact.email_placeholder')}</span>
                <Copy class="size-6 opacity-0 group-hover:opacity-100 transition-opacity"/>
              </button>
            </div>
          </div>
          <div class="select-none flex items-center gap-4">
            <div class="w-12 h-12 rounded-full glass-panel ghost-border flex items-center justify-center text-brand-secondary">
              <Location class="size-6" />
            </div>
            <div>
              <div class="font-label text-small uppercase text-brand-on-surface-variant">{t('contact.location_label')}</div>
              <div class="font-body text-sm">{t('contact.location')}</div>
            </div>
          </div>
        </div>
        <div class="flex gap-3 mt-8">
          <a class="w-10 h-10 rounded-full glass-panel ghost-border flex items-center justify-center text-brand-on-surface dark:text-brand-on-surface hover:scale-110 transition-all duration-300 cursor-pointer border-none" href="https://github.com/Xetha666" target="_blank" rel="noopener noreferrer" aria-label={t('contact.github_aria')} title="GitHub">
            <GithubIcon class="size-5" />
          </a>
          <button id="open-whatsapp" class="w-10 h-10 rounded-full glass-panel ghost-border flex items-center justify-center text-success hover:scale-110 transition-all duration-300 cursor-pointer border-none" aria-label={t('contact.whatsapp_aria')} title="WhatsApp">
            <WhatsAppIcon class="size-5" />
          </button>
          <button id="open-discord" class="w-10 h-10 rounded-full glass-panel ghost-border flex items-center justify-center text-brand-discord hover:scale-110 transition-all duration-300 border-none cursor-pointer" aria-label={t('contact.discord_aria')} title="Discord">
            <DiscordIcon class="size-5" />
          </button>
        </div>
      </div>
      <div class="timeline-view animate-slide-in-right animate-range-[entry_5%_contain_30%]">
        <ContactForm />
      </div>
    </div>
  </div>
</section>

<script>
  function setupEmailCopy() {
    const copyEmailBtn = document.getElementById("copy-email");
    const emailText = document.getElementById("email-display-text");

    const encodedEmail = "YnJ5YW5kZXY3ODk2QGdtYWlsLmNvbQ==";

    if (copyEmailBtn && emailText) {
      if (copyEmailBtn.dataset.setup) return;
      copyEmailBtn.dataset.setup = "true";
      
      const copiedText = copyEmailBtn.dataset.copiedText || "Copiado";

      copyEmailBtn.addEventListener("click", () => {
        const email = atob(encodedEmail);

        navigator.clipboard
          .writeText(email)
          .then(() => {
            const originalText = emailText.innerText;
            emailText.innerText = copiedText;
            emailText.classList.add("text-brand-primary", "font-bold");

            setTimeout(() => {
              emailText.innerText = originalText;
              emailText.classList.remove("text-brand-primary", "font-bold");
            }, 2000);
          })
          .catch((err) => {
            console.error("Error al copiar email: ", err);
          });
      });
    }
  }

  function setupWhatsApp() {
    const encodedPhone = "NTE5ODIyMTc3Mjk=";
    const message = "Hola Bryan, vi tu portafolio y me gustaría contactarte.";

    const openHandler = () => {
      const phone = atob(encodedPhone);
      window.open(
        `https://wa.me/${phone}?text=${encodeURIComponent(message)}`,
        "_blank",
      );
    };

    const openWaBtn = document.getElementById("open-whatsapp") as HTMLButtonElement | null;
    if (openWaBtn && !openWaBtn.dataset.setup) {
      openWaBtn.addEventListener("click", openHandler);
      openWaBtn.dataset.setup = "true";
    }
  }

  function setupDiscord() {
    const encodedId = "NDc1Nzg5MDU3MjA5NjYzNDg5";

    const openDiscordBtn = document.getElementById("open-discord") as HTMLButtonElement | null;
    if (openDiscordBtn && !openDiscordBtn.dataset.setup) {
      openDiscordBtn.addEventListener("click", () => {
        const id = atob(encodedId);
        window.open(`https://discord.com/users/${id}`, "_blank");
      });
      openDiscordBtn.dataset.setup = "true";
    }
  }

  setupEmailCopy();
  setupWhatsApp();
  setupDiscord();
  document.addEventListener("astro:after-swap", () => {
    setupEmailCopy();
    setupWhatsApp();
    setupDiscord();
  });
</script>
