---
import ThemeController from "@/components/ThemeController.astro";
import { Options } from "@/types/menu";
import { Image } from "astro:assets";
import logoLight from "@/assets/logo-light.webp";
import logoDark from "@/assets/logo-dark.webp";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import SpainFlag from "@/components/icons/SpainFlag.astro";
import AmericaFlag from "@/components/icons/AmericaFlag.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<nav class="flex items-center justify-between px-6 py-3 rounded-full mt-4 mx-auto w-11/12 max-w-5xl glass-panel border border-brand-outline-variant/30 nav-shadow sticky top-4 z-50 animate-slide-in-top animate-duration-700">
  <a href={lang === 'es' ? '/' : `/${lang}/`} class="transition-transform duration-300 active:scale-95">
    <Image src={logoLight} alt="bryan.dev Logo" class="h-8 w-auto block dark:hidden" loading="eager" fetchpriority="high" />
    <Image src={logoDark} alt="bryan.dev Logo" class="h-8 w-auto hidden dark:block" loading="eager" fetchpriority="high" />
  </a>

  <!-- Desktop Menu -->
  <div class="hidden md:flex items-center gap-1 bg-brand-on-background/5 dark:bg-brand-on-surface/5 p-1 rounded-full border border-brand-outline-variant/10">
    {
      Options.map((option) => {
        return (
          <a 
            href={option.href} 
            class:list={[
              "flex items-center gap-2 px-4 py-2 rounded-full transition-colors duration-500 ease-out text-sm font-medium",
              "text-brand-on-surface-variant hover:text-brand-primary dark:text-brand-on-surface-variant dark:hover:text-brand-primary hover:bg-brand-surface-container/50 dark:hover:bg-brand-primary/5"
            ]}
            data-nav-link={option.href.replace("#", "")}
          >
            <span>{t(option.key as any)}</span>
          </a>
        );
      })
    }
  </div>

  <div class="flex items-center gap-2">
    <!-- Language Selector -->
    <div class="relative" id="lang-picker-container">
      <button 
        id="lang-button"
        aria-label={t('common.change_lang')}
        aria-expanded="false"
        aria-haspopup="true"
        class="flex items-center gap-2 px-3 py-2 rounded-full hover:bg-brand-primary/10 transition-all duration-300 text-brand-on-surface-variant active:scale-95 group/langbtn cursor-pointer"
      >
        <div class="size-7 flex items-center justify-center shrink-0">
          {lang === 'es' ? <SpainFlag class="size-full" /> : <AmericaFlag class="size-full" />}
        </div>
        <span class="font-label text-xs font-bold uppercase tracking-widest">{lang}</span>
      </button>
      <div 
        id="lang-dropdown"
        class="absolute right-0 top-full mt-2 opacity-0 pointer-events-none translate-y-2 transition-all duration-300 z-60"
      >
        <div class="glass-panel border border-brand-outline-variant/20 rounded-2xl p-2 min-w-36 shadow-xl overflow-hidden backdrop-blur-3xl">
          <a
            href="/"
            class:list={[
              "flex items-center gap-3 px-4 py-2 rounded-xl text-sm transition-colors",
              lang === 'es' ? "bg-brand-primary/20 text-brand-primary font-bold" : "text-brand-on-surface-variant hover:bg-brand-primary/10 hover:text-brand-primary"
            ]}
          >
            <SpainFlag class="size-5 shrink-0" /> Español
          </a>
          <a 
            href="/en/"
            class:list={[
              "flex items-center gap-3 px-4 py-2 rounded-xl text-sm transition-colors mt-1",
              lang === 'en' ? "bg-brand-primary/20 text-brand-primary font-bold" : "text-brand-on-surface-variant hover:bg-brand-primary/10 hover:text-brand-primary"
            ]}
          >
            <AmericaFlag class="size-5 shrink-0" /> English
          </a>
        </div>
      </div>
    </div>

    <div class="w-px h-4 bg-accent-content dark:bg-accent-content mx-1"></div>

    <button aria-label={t('common.change_theme')}>
      <ThemeController/>
    </button>
  </div>
</nav>

<script>
  function setupNavbar() {
    const navLinks = document.querySelectorAll("nav.sticky [data-nav-link]");
    const sections = document.querySelectorAll("section[id]");

    const activeClasses = ["text-brand-primary", "bg-brand-primary/10", "dark:text-brand-primary", "dark:bg-brand-primary/10"];
    const inactiveClasses = ["text-brand-on-surface-variant", "dark:text-brand-on-surface-variant"];

    const observerOptions = {
      root: null,
      rootMargin: "-40% 0px -40% 0px",
      threshold: 0,
    };

    const observerCallback = (entries: IntersectionObserverEntry[]) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const id = entry.target.getAttribute("id");
          navLinks.forEach((link) => {
            if (link.getAttribute("data-nav-link") === id) {
              link.classList.add(...activeClasses);
              link.classList.remove(...inactiveClasses);
            } else {
              link.classList.remove(...activeClasses);
              link.classList.add(...inactiveClasses);
            }
          });
        }
      });
    };

    const observer = new IntersectionObserver(observerCallback, observerOptions);
    sections.forEach((section) => observer.observe(section));
  }

  function setupLanguagePicker() {
    const btn = document.getElementById('lang-button');
    const dropdown = document.getElementById('lang-dropdown');
    
    if (!btn || !dropdown) return;

    const toggle = (forceClose = false) => {
      const isExpanded = btn.getAttribute('aria-expanded') === 'true';
      const shouldOpen = forceClose ? false : !isExpanded;
      
      btn.setAttribute('aria-expanded', shouldOpen.toString());
      
      if (shouldOpen) {
        dropdown.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-2');
        dropdown.classList.add('opacity-100', 'translate-y-0');
      } else {
        dropdown.classList.add('opacity-0', 'pointer-events-none', 'translate-y-2');
        dropdown.classList.remove('opacity-100', 'translate-y-0');
      }
    };

    // Use a single click handler for the button
    btn.onclick = (e) => {
      e.stopPropagation();
      toggle();
    };

    // Close on click outside, but allow clicks inside dropdown to bubble for navigation
    document.onclick = (e) => {
      const target = e.target as Node;
      if (!btn.contains(target) && !dropdown.contains(target)) {
        toggle(true);
      }
    };

    // Ensure links close the dropdown after being clicked (for mobile UX)
    dropdown.querySelectorAll('a').forEach(link => {
      link.onclick = () => {
        // Delay closing slightly to allow navigation to start
        setTimeout(() => toggle(true), 100);
      };
    });

    // Close on escape key
    document.onkeydown = (e) => {
      if (e.key === 'Escape') toggle(true);
    };
  }

  setupNavbar();
  setupLanguagePicker();
  
  document.addEventListener('astro:after-swap', () => {
    setupNavbar();
    setupLanguagePicker();
  });
</script>

<style>
  .nav-shadow {
    box-shadow: 0 0 20px rgba(0, 106, 110, 0.1);
  }
</style>
