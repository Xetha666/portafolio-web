---
import { Options } from "@/types/menu";
import Home from "@/components/icons/Home.astro";
import Projects from "@/components/icons/Projects.astro";
import About from "@/components/icons/About.astro";
import Contact from "@/components/icons/Contact.astro";

const IconMap: Record<string, any> = {
  "Inicio": Home,
  "Proyectos": Projects,
  "Sobre mi": About,
  "Contacto": Contact
};
---

<nav class="fixed bottom-0 left-0 w-full z-50 flex justify-around items-center px-4 pb-6 pt-3 md:hidden bg-slate-900/60 dark:bg-black/60 backdrop-blur-2xl border-t border-cyan-500/20 rounded-t-4xl shadow-[0_-10px_40px_rgba(0,0,0,0.5)]">
  {
    Options.map((option, index) => {
      const Icon = IconMap[option.name];
      return (
        <a 
          href={option.href} 
          class:list={[
            "flex flex-col items-center justify-center px-4 py-1 rounded-xl transition duration-300 ease-out active:translate-y-[-2px]",
            index === 0 ? "text-cyan-300 bg-cyan-500/10" : "text-slate-500 hover:text-cyan-400"
          ]}
          data-nav-link={option.href.replace("#", "")}
        >
          {Icon && <Icon class="size-5" />}
          <span class="font-manrope text-[10px] uppercase tracking-widest mt-1">{option.name}</span>
        </a>
      );
    })
  }
</nav>

<script>
  const navLinks = document.querySelectorAll("[data-nav-link]");
  const sections = document.querySelectorAll("section[id]");

  const activeClasses = ["text-cyan-300", "bg-cyan-500/10"];
  const inactiveClasses = ["text-slate-500", "hover:text-cyan-400"];

  const observerOptions = {
    root: null,
    rootMargin: "-40% 0px -80% 0px",
    threshold: 0,
  };

  const observerCallback = (entries: IntersectionObserverEntry[]) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const id = entry.target.getAttribute("id");
        navLinks.forEach((link) => {
          if (link.getAttribute("data-nav-link") === id) {
            link.classList.add(...activeClasses);
            link.classList.remove(...inactiveClasses);
          } else {
            link.classList.remove(...activeClasses);
            link.classList.add(...inactiveClasses);
          }
        });
      }
    });
  };

  const observer = new IntersectionObserver(observerCallback, observerOptions);
  sections.forEach((section) => observer.observe(section));
</script>