---
import { skillCategories } from "@/types/skills";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="mb-32 scroll-mt-12 md:scroll-mt-24 lg:scroll-mt-32" id="about">
  <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-center">
    <div class="md:col-span-7 flex flex-col gap-8">
      <h2 class="font-headline select-none text-4xl font-bold timeline-view animate-slide-in-left animate-range-[entry_5%_contain_25%]">{t('about.title')}</h2>
      <div class="space-y-4 font-body select-none text-brand-on-surface-variant leading-relaxed text-lg">
        <p>
          {t('about.p1')}
        </p>
        <p set:html={t('about.p2')} />
      </div>
      <div class="grid grid-cols-2 select-none gap-4 mt-4 timeline-view animate-fade-in animate-range-[entry_10%_contain_40%]">
        <div class="p-6 rounded-2xl glass-panel ghost-border">
          <div class="text-brand-primary font-headline text-3xl font-bold mb-1">3+</div>
          <div class="font-label text-xs uppercase tracking-widest text-brand-on-surface-variant">{t('about.stats.projects')}</div>
        </div>
        <div class="p-6 rounded-2xl glass-panel ghost-border">
          <div class="text-brand-secondary font-headline text-3xl font-bold mb-1">6+</div>
          <div class="font-label text-xs uppercase tracking-widest text-brand-on-surface-variant">{t('about.stats.experience')}</div>
        </div>
      </div>
    </div>
    
    <div class="md:col-span-5 flex flex-col gap-6 timeline-view animate-slide-in-right animate-range-[entry_5%_contain_30%]">
      <div class="glass-panel select-none rounded-[2.5rem] p-8 ghost-border h-full">
        <h4 class="font-label text-sm uppercase tracking-widest text-brand-primary mb-8 text-center italic">{t('about.tech_stack')}</h4>
        
        <div class="space-y-8">
          {skillCategories.map((category) => (
            <div class="space-y-4">
              <h5 class="font-label text-xs uppercase tracking-wide text-brand-on-surface-variant/60 font-semibold">
                {lang === 'es' ? category.title : (category as any).titleEn || category.title}
              </h5>
              <div class="flex flex-wrap gap-2">
                {category.items.map(({ name, Icon, learning }) => (
                  <div 
                    class="select-none group relative flex items-center gap-2 px-3 py-1.5 rounded-full border border-brand-outline-variant/30 bg-brand-surface-container-lowest/20 dark:bg-brand-surface-container-highest/10 backdrop-blur-sm transition-all duration-300 hover:scale-105 hover:border-brand-primary/30 hover:bg-brand-surface-container-lowest/40 cursor-default"
                  >
                    <Icon class="size-4 transition-transform group-hover:rotate-12" />
                    <span class="font-label text-sm font-medium text-brand-on-surface whitespace-nowrap">
                      {name}
                    </span>
                    {learning && (
                      <span class="text-small bg-brand-secondary/10 text-brand-secondary px-2 py-0.5 rounded-full font-bold border border-brand-secondary/20">
                        {t('about.learning')}
                      </span>
                    )}
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .text-glow {
    text-shadow: 0 0 15px currentColor;
    filter: brightness(1.2);
  }
</style>
