---
import About from "@/components/About.astro";
import Contact from "@/components/Contact.astro";
import Footer from "@/components/Footer.astro";
import Hero from "@/components/Hero.astro";
import Loader from "@/components/Loader.astro";
import Navbar from "@/components/Navbar.astro";
import NavMobile from "@/components/NavMobile.astro";
import Projects from "@/components/Projects.astro";
import Layout from "@/layouts/Layout.astro";
---

<Layout>
  <Navbar/>
  <main class="relative z-10 px-6 pt-8 pb-24 max-w-5xl mx-auto">
    <Hero/>
    <section id="projects" class="mb-32 scroll-mt-4 md:scroll-mt-24">
      <Projects lang="id" server:defer>
        <Loader slot="fallback"/>
      </Projects>
    </section>
    <About/>
    <Contact/>
  </main>
  <Footer/>
  <NavMobile/>
</Layout>
