---
import Home from "@/components/icons/Home.astro";
import Layout from "@/layouts/Layout.astro";
import Rocket from "public/svg/Rocket.svg";
import World from "public/svg/World.svg";
---

<Layout title="404 - Pagina no encontrada">
  <main class="relative z-10 w-full min-h-screen grid place-items-center px-6 overflow-hidden">
    <!-- Elementos Decorativos Espaciales con mayor opacidad -->
    <div class="absolute top-1/4 left-1/10 text-brand-primary opacity-30 animate-float pointer-events-none">
      <World class="size-20 md:size-32 rotate-12" />
    </div>
    <div class="absolute bottom-1/4 right-1/10 text-brand-secondary opacity-30 animate-float-delayed pointer-events-none">
      <Rocket class="size-16 md:size-24 -rotate-45" />
    </div>
    
    <!-- Estrellas brillantes de fondo -->
    <div class="absolute top-1/2 right-1/4 w-2 h-2 bg-white rounded-full animate-pulse shadow-white"></div>
    <div class="absolute bottom-1/3 left-1/4 w-1.5 h-1.5 bg-brand-primary rounded-full animate-pulse delay-700 shadow-brand-primary"></div>

    <div class="glass-panel p-10 md:p-20 rounded-4xl ghost-border flex flex-col items-center gap-8 max-w-2xl relative z-20 backdrop-blur-2xl shadow-2xl border-white/10 dark:bg-white/5">
      <!-- Luces de acento para mejorar contraste -->
      <div class="absolute -top-20 -left-20 w-40 h-40 bg-brand-primary/30 blur-huge -z-10 rounded-full"></div>
      <div class="absolute -bottom-20 -right-20 w-40 h-40 bg-brand-secondary/30 blur-huge -z-10 rounded-full"></div>

      <div class="relative group">
        <!-- 404 con degradado más vibrante -->
        <h1 class="font-headline text-9xl md:text-9xl font-bold text-transparent bg-clip-text bg-linear-to-br from-brand-primary via-white to-brand-secondary select-none leading-none filter drop-shadow-brand-404 transition-transform duration-700 group-hover:scale-105">
          404
        </h1>
        <div class="absolute -top-6 -right-6 size-16 bg-brand-primary/20 rounded-full blur-2xl animate-pulse"></div>
      </div>
      
      <div class="space-y-6 max-w-lg">
        <!-- Título con contraste máximo -->
        <h2 class="font-headline text-3xl md:text-5xl font-bold tracking-tight text-brand-on-surface">Misión Interrumpida</h2>
        <!-- Texto descriptivo con contraste mejorado -->
        <p class="font-body text-brand-on-surface text-lg md:text-xl leading-relaxed opacity-95">
          Parece que has entrado en un agujero de gusano. La página que buscas ha derivado fuera de nuestro alcance.
        </p>
      </div>

      <div class="flex flex-col sm:flex-row gap-4 w-full justify-center mt-6">
        <a 
          href="/" 
          class="ion-drive-button group cursor-pointer px-10 py-5 rounded-2xl text-black font-bold font-label uppercase tracking-widest text-sm flex items-center justify-center gap-3 active:scale-95 transition-all hover:shadow-brand-404"
        >
          <Home class="size-5 transition-transform group-hover:-translate-y-1" />
          Volver a la Base
        </a>
      </div>
    </div>
  </main>
</Layout>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0) rotate(12deg); }
    50% { transform: translateY(-30px) rotate(15deg); }
  }

  @keyframes float-delayed {
    0%, 100% { transform: translateY(0) rotate(-45deg); }
    50% { transform: translateY(40px) rotate(-40deg); }
  }
  .shadow-white {
    box-shadow: 0 0 15px white;
  }

  .shadow-brand-primary {
    box-shadow: 0 0 15px var(--color-brand-primary);
  }

  .shadow-brand-404{
    box-shadow: 0 0 40px rgba(161,250,255,0.4);
  }

  .drop-shadow-brand-404{
    filter: drop-shadow(0 0 40px rgba(161,250,255,0.4));
  }

  .animate-float {
    animation: float 6s ease-in-out infinite;
  }

  .animate-float-delayed {
    animation: float-delayed 8s ease-in-out infinite;
    animation-delay: 1s;
  }

  /* Fondo de puntos mejorado */
  main {
    background-image: 
      radial-gradient(circle at 2px 2px, rgba(255,255,255,0.1) 1.5px, transparent 0);
    background-size: 50px 50px;
  }
</style>
